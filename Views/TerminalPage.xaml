<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="shanPro.Views.TerminalPage"
             BackgroundColor="{StaticResource TerminalBg}"
             Title="Terminal">
    <VerticalStackLayout>
        <ScrollView VerticalOptions="FillAndExpand">
            <Label x:Name="TerminalOutput" TextColor="{StaticResource TerminalText}" FontFamily="Courier New" FontSize="14"/>
        </ScrollView>
        <HorizontalStackLayout Spacing="5" Padding="5">
            <Label Text="$ " TextColor="Lime" FontFamily="Courier New" FontSize="14"/>
            <Entry x:Name="CmdInput" TextColor="Lime" BackgroundColor="Black" WidthRequest="300" ReturnType="Send" Completed="OnCommandEnter"/>
        </HorizontalStackLayout>
    </VerticalStackLayout>
</ContentPage>
